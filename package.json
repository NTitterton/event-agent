{
  "name": "event-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud-hosted event-driven agent platform for scheduled and triggered agent jobs.",
  "type": "module",
  "scripts": {
    "dev:api": "tsx src/server/index.ts",
    "dev:worker": "tsx src/worker/index.ts",
    "dev:ui": "vite src/ui --host 127.0.0.1",
    "check": "tsc --noEmit",
    "test": "node --test --import tsx scripts/*.test.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "github:push": "tsx scripts/github-push.ts"
  },
  "dependencies": {
    "@aws-sdk/client-scheduler": "^3.600.0",
    "@aws-sdk/client-sqs": "^3.600.0",
    "fastify": "^4.28.1",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
